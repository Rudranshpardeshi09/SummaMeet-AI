# =============================================================================
# AI Video Note Taker — Environment Configuration
# Copy this file to .env and fill in values for local development
# =============================================================================

# ---- Application ----
APP_NAME=ai-video-note-taker
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ---- FastAPI ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:8001","http://localhost:3000"]

# ---- Django Dashboard ----
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_note_taker
POSTGRES_USER=notetaker
POSTGRES_PASSWORD=notetaker_dev_password
DATABASE_URL=postgresql+asyncpg://notetaker:notetaker_dev_password@localhost:5432/ai_note_taker

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---- MinIO (S3-Compatible Object Storage) ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AUDIO=audio-chunks
MINIO_BUCKET_REPORTS=report-artifacts
MINIO_USE_SSL=false

# ---- JWT Auth (RS256) ----
# Generate keys: openssl genrsa -out jwt_private.pem 2048
#                openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
JWT_PRIVATE_KEY_PATH=./jwt_keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./jwt_keys/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=RS256

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Gemini API (Free Tier) ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- Ollama (Local LLM Fallback) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ---- Encryption ----
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# ---- Rate Limiting ----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ---- Seed Data ----
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_PASSWORD=admin123456
SEED_ORG_NAME=Default Organization
SEED_ORG_SLUG=default-org

# ---- Bot Worker ----
# API key generated by `make db-seed` (save the output!)
BOT_API_KEY=change-me-to-seeded-bot-api-key
# Dedicated Google account for the bot
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
# Browser behavior
HEADLESS=true
LOBBY_TIMEOUT_SECONDS=600
MAX_JOIN_RETRIES=3
# Audio chunk interval
AUDIO_CHUNK_DURATION_SECONDS=30

# ---- Transcription Worker ----
# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL_SIZE=small
# Device: auto, cpu, cuda
WHISPER_DEVICE=auto
# Compute type: auto, int8, float16, float32
WHISPER_COMPUTE_TYPE=auto

